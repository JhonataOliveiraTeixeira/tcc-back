{
  "compilerOptions": {
    "module": "CommonJS", 
    "target": "ES2021",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "moduleResolution": "node",
    "types": ["node"], 

    // Metadata & Decorators (Obrigatório para NestJS)
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    
    // Output Settings
    "noEmit": false, 
    "outDir": "./dist",
    "sourceMap": true,
    "baseUrl": "./",

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Path aliases
    "paths": {
      "generated/*": ["generated/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}