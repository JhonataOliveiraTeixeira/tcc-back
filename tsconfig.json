{
  "compilerOptions": {

    // ... manter o restante igual
    "module": "NodeNext", // Melhor compatibilidade com Vercel
    "moduleResolution": "NodeNext",
    "noEmit": false, // OBRIGATÓRIO ser false para o build funcionar
    "outDir": "./dist", // Define para onde vão os arquivos compilados
    
    // Remova ou comente essa linha se estiver no modo de produção
    "allowImportingTsExtensions": false,

    // "noEmit": false, // Obrigatório para gerar a pasta /dist
    // "outDir": "./dist",
    // Enable latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    // "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,

    "types": [
      "bun"
    ],

    // Bundler mode
    // "moduleResolution": "bundler",
    // "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    // "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // For NestJS
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,

    // Path aliases
    "paths": {
      "@/*": ["./src/*"],
      "generated/*": ["./generated/*"]
    }
  }
}
