{
  "name": "nestjs-bun-test",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "module": "src/main.ts",
  "scripts": {
    "build": "bunx prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r tsconfig-paths/register dist/main.js",
    "start:dev": "NODE_ENV=development tsc-watch --onSuccess \"bun .\"",
    "start:debug": "NODE_ENV=development tsc-watch --onSuccess \"bun . --inspect\"",
    "start:prod": "node -r tsconfig-paths/register dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:debug": "bun --inspect-brk --runInBand",
    "test:e2e": "bun test ./test/app.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^6.18.0",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "vercel": "^50.25.5"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/bun": "^1.3.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.18.0",
    "supertest": "^7.0.0",
    "tsc-watch": "^6.2.1",
    "typescript": "^5.1.3"
  },
  "trustedDependencies": [
    "@nestjs/core"
  ]
}
